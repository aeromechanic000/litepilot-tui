# @LITE_DESC .env.example with common environment variables for web apps: database, redis, auth, feature flags, and logging
# @LITE_SCENE web-app
# @LITE_TAGS env,config,environment,variables,dotenv

# ========== Application ==========
APP_NAME=myapp
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
APP_PORT=3000
APP_KEY=generate-a-secret-key-here
APP_TIMEZONE=UTC
APP_LOCALE=en_US

# ========== Database - PostgreSQL ==========
DATABASE_CONNECTION=pgsql
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=myapp
DATABASE_USER=postgres
DATABASE_PASSWORD=secret
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30
DATABASE_SSL_MODE=prefer
DATABASE_MAX_CONNS=100
DATABASE_MIN_CONNS=10

# ========== Database - MySQL ==========
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=myapp
# MYSQL_USER=root
# MYSQL_PASSWORD=secret

# ========== Database - SQLite ==========
# SQLITE_PATH=./database.sqlite

# ========== Database - MongoDB ==========
# MONGODB_HOST=127.0.0.1
# MONGODB_PORT=27017
# MONGODB_DATABASE=myapp
# MONGODB_USER=mongouser
# MONGODB_PASSWORD=secret

# ========== Redis ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_PREFIX=myapp:
REDIS_TTL=3600
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# ========== Auth / Security ==========
JWT_SECRET=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# OAuth providers
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Password settings
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_COOKIE_NAME=session

# ========== Email ==========
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_FROM_EMAIL=noreply@example.com

# ========== Storage / Files ==========
FILESYSTEM_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
CDN_URL=

# Local storage
LOCAL_STORAGE_PATH=./storage

# ========== Logging ==========
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DAYS=14
LOG_MAX_FILES=30

# Log channels: single, daily, syslog, errorlog
LOG_STDERR_LOG_LEVEL=error
LOG_STDOUT_LOG_LEVEL=info

# Sentry
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ========== Caching ==========
CACHE_DRIVER=redis
CACHE_PREFIX=cache
CACHE_TTL=3600
CACHE_LOCK_TTL=30

# ========== Queue / Jobs ==========
QUEUE_CONNECTION=redis
QUEUE_DRIVER=redis
QUEUE_TUBE=default
QUEUE_WORKER_COUNT=2
QUEUE_RETRY_AFTER=90
QUEUE_MAX_TRIES=3
QUEUE_TIMEOUT=60

# ========== Rate Limiting ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=60
RATE_LIMIT_DECAY=60
RATE_LIMIT_BLOCK_FOR=60

# ========== CORS ==========
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=7200

# ========== Feature Flags ==========
FEATURE_API_V2=false
FEATURE_NEW_UI=false
FEATURE_BETA_FEATURES=false
FEATURE_MAINTENANCE_MODE=false
FEATURE_SIGNUPS_ENABLED=true
FEATURE_EMAIL_VERIFICATION_REQUIRED=true

# ========== Third-party APIs ==========
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_ENDPOINT=/webhooks/stripe

GITHUB_API_TOKEN=
GITHUB_WEBHOOK_SECRET=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# ========== Monitoring / Analytics ==========
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=
PLAUSIBLE_DOMAIN=
MATOMO_URL=
MATOMO_SITE_ID=

# ========== Search =##
ELASTICSEARCH_HOST=127.0.0.1
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=myapp

# Algolia
# ALGOLIA_APP_ID=
# ALGOLIA_API_KEY=
# ALGOLIA_SEARCH_API_KEY=

# ========== SMS / Notifications =##
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

NEXMO_API_KEY=
NEXMO_API_SECRET=

# ========== Content Security =##
CONTENT_SECURITY_POLICY_ENABLED=false
CONTENT_SECURITY_POLICY_DIRECTIVES="default-src 'self'"
FRAME_ANCESTORS=self

# ========== Localization =##
DEFAULT_LOCALE=en
FALLBACK_LOCALE=en
AVAILABLE_LOCALES=en,es,fr,de,ja,zh
TIMEZONE=UTC
DATE_FORMAT=Y-m-d
TIME_FORMAT=g:i A

# ========== Pagination =##
PAGINATION_DEFAULT_PER_PAGE=20
PAGINATION_MAX_PER_PAGE=100

# ========== Upload =##
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,application/pdf

# ========== WebSocket =##
WS_ENABLED=false
WS_PORT=3001
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL=30000

# ========== Testing =##
TESTING_DATABASE_HOST=127.0.0.1
TESTING_DATABASE_NAME=test_myapp
TESTING_REDIS_HOST=127.0.0.1
TESTING_REDIS_DB=15
TESTING_MAIL_DRIVER=array

# ========== Development =##
DEV_HOT_RELOAD=true
DEV_PROXY_PORT=8080
DEV_DEBUG_BAR=true
DEV_LOG_QUERIES=true
